{
  "name": "@presstronic-academy/ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./src/styles/academy.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check": "pnpm lint && pnpm typecheck",
    "format": "prettier --check --ignore-path ../../.prettierignore .",
    "lint": "eslint src",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "tailwind-merge": "^2.5.2"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  },
  "devDependencies": {
    "@presstronic-academy/eslint-config": "workspace:*",
    "@presstronic-academy/tsconfig": "workspace:*",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.9.0",
    "typescript": "^5.5.4"
  }
}
