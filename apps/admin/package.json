{
  "name": "@presstronic-academy/admin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json && vite build",
    "check": "pnpm lint && pnpm typecheck",
    "dev": "vite --host 0.0.0.0 --port 5174",
    "format": "prettier --check --ignore-path ../../.prettierignore .",
